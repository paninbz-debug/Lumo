# /api/lead → e-mail (через Resend) + Telegram-bot.
# Если переменные не выставлены — endpoint всё равно отвечает 200,
# но в логах будет "no channel configured" (frontend покажет fallback toast).

# — Resend (https://resend.com) —
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
LUMO_LEAD_TO=panin.bz@gmail.com
# Должен быть e-mail на верифицированном в Resend домене.
# Для теста можно "LUMO <onboarding@resend.dev>".
LUMO_LEAD_FROM=LUMO <lumo@your-verified-domain.ru>

# — Telegram bot (BotFather) —
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# chat_id, куда бот шлёт уведомления. Получить:
#   1. Создать бота через @BotFather → /newbot
#   2. Добавить бота в чат / личку
#   3. Открыть https://api.telegram.org/bot<TOKEN>/getUpdates → взять `chat.id`
LUMO_TG_CHAT_ID=-100xxxxxxxxxx
